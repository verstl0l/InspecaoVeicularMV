<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#F5F5F5"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvNomeSubItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sub-item"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTirarFotoSubItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tirar Foto"
            android:layout_marginEnd="4dp"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnSelecionarFotoSubItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Galeria"
            android:layout_marginStart="4dp"
            android:textSize="11sp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <ImageView
            android:id="@+id/ivFotoSubItem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:src="@drawable/ic_image_placeholder"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOkSubItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="OK"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIrregularSubItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="IRREGULAR"
            android:layout_marginStart="4dp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatusSubItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Aguardando"
        android:textSize="11sp"
        android:paddingTop="4sp"
        android:textColor="#999999"/>

</LinearLayout>