<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/border_dashed"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvNomeItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Item"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"
        android:textColor="#2196F3"/>

    <!-- Container para sub-itens (fotos múltiplas) -->
    <LinearLayout
        android:id="@+id/containerSubItens"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- Campo de observação do item -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etObservacaoItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Observação (opcional)" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvStatusItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Aguardando"
        android:textSize="12sp"
        android:paddingTop="4sp"
        android:textColor="#999999"/>

</LinearLayout>