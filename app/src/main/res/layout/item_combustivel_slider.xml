<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/border_dashed"
    android:layout_marginBottom="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nível do Combustível"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"
        android:textColor="#2196F3"/>

    <SeekBar
        android:id="@+id/seekBarCombustivel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="4"
        android:progress="0"
        android:thumb="@drawable/thumb_azul"
        android:progressTint="#2196F3"
        android:thumbTint="#2196F3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reserva"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="#FF9800"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1/4"
            android:textSize="12sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1/2"
            android:textSize="12sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="3/4"
            android:textSize="12sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cheio"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="#4CAF50"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvNivelCombustivel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nível selecionado: Reserva"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingTop="8dp"
        android:textStyle="bold"/>

</LinearLayout>