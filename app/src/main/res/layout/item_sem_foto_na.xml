<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/border_dashed"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvNomeSemFotoNA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Item"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOkSemFotoNA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="OK"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIrregularSemFotoNA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="IRREGULAR"
            android:layout_marginStart="4dp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNaoSeAplicaSemFotoNA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="N/A"
            android:layout_marginStart="4dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatusSemFotoNA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Aguardando"
        android:textSize="12sp"
        android:paddingTop="4sp"
        android:textColor="#999999"/>

</LinearLayout>